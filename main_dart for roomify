}

class _BudgetPlannerPageState extends State<BudgetPlannerPage> {
  final TextEditingController budgetController =
      TextEditingController(text: '50000');

  double furniture = 0;
  double decor = 0;
  double lighting = 0;
  double paint = 0;

  @override
  void initState() {
    super.initState();
    _calculate();
  }

  void _calculate() {
    final total = double.tryParse(budgetController.text) ?? 0;
    setState(() {
      furniture = total * 0.50;
      decor = total * 0.15;
      lighting = total * 0.15;
      paint = total * 0.20;
    });
